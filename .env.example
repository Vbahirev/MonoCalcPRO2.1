VITE_FIREBASE_API_KEY=YOUR_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_DOMAIN
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_BUCKET
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID
VITE_FIREBASE_MEASUREMENT_ID=YOUR_MEASUREMENT_ID

# Optional: runtime host allowlist (defense-in-depth).
# Comma-separated hostnames where this build is allowed to run.
# This does NOT replace proper API key restrictions in Google Cloud Console.
VITE_ALLOWED_HOSTS=localhost,127.0.0.1

# Project owner UID (superadmin override in app UI)
VITE_SUPERADMIN_UID=

# Absolute superadmin email override
VITE_SUPERADMIN_EMAIL=viktor19971997@gmail.com
